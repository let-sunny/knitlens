{
  "name": "knitlens",
  "version": "1.0.0",
  "description": "KnitLens is an AI-assisted knitting pattern interpreter for human knitters.",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "next dev --no-turbopack",
    "dev:fresh": "lsof -ti :3000 | xargs kill -9 2>/dev/null; next dev --hostname localhost --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/let-sunny/knitlens.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/let-sunny/knitlens/issues"
  },
  "homepage": "https://github.com/let-sunny/knitlens#readme",
  "dependencies": {
    "@sakun/system.css": "^0.1.11",
    "@supabase/supabase-js": "^2.47.0",
    "pdf-parse": "^1.1.1",
    "server-only": "^0.0.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0"
  }
}
